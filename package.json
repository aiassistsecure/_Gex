{
  "name": "jenny-python-desktop-generator",
  "version": "1.0.0",
  "description": "Jenny — The Electron for Python Developers. Build desktop apps with Python + Electron + Agents.",
  "private": true,
  "workspaces": [
    "cli",
    "core"
  ],
  "scripts": {
    "dev": "node scripts/dev.js",
    "build": "node scripts/build-python.js && node scripts/build-electron.js",
    "package": "node scripts/build-electron.js --package",
    "clean": "rimraf dist build",
    "cli": "node cli/bin/jenny.js"
  },
  "keywords": [
    "electron",
    "python",
    "desktop",
    "framework",
    "agent",
    "generator"
  ],
  "author": "Jenny Contributors",
  "license": "MIT",
  "devDependencies": {
    "rimraf": "^5.0.5"
  }
}
