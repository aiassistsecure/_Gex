{
  "name": "test-app",
  "version": "1.0.0",
  "private": true,
  "description": "test-app — A Jenny desktop application",
  "main": "electron/main.js",
  "scripts": {
    "dev": "jenny dev",
    "dev:frontend": "cd frontend && npx vite --port 3000",
    "dev:backend": "cd backend && python -m uvicorn app:app --reload --port 18764",
    "build": "jenny build",
    "package": "jenny package",
    "start": "electron ."
  },
  "dependencies": {
    "ws": "^8.16.0"
  },
  "devDependencies": {
    "electron": "^28.1.3",
    "electron-builder": "^24.9.1"
  },
  "build": {
    "appId": "com.jenny.test-app",
    "productName": "test-app",
    "asar": true,
    "asarUnpack": "resources/python/**",
    "extraResources": [
      {
        "from": "backend/dist/",
        "to": "python",
        "filter": ["**/*"]
      }
    ],
    "win": {
      "target": [
        { "target": "nsis",     "arch": ["x64"] },
        { "target": "portable", "arch": ["x64"] }
      ]
    },
    "mac": { "target": "dmg" },
    "linux": { "target": "AppImage" }
  }
}
