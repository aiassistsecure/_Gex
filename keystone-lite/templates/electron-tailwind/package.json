{
  "name": "electron-tailwind-app",
  "version": "1.0.0",
  "description": "Electron desktop app with Tailwind CSS and TypeScript",
  "main": "dist/main/index.js",
  "scripts": {
    "dev": "concurrently \"npm run watch:css\" \"npm run watch:ts\" \"wait-on dist/main/index.js && electron .\"",
    "watch:css": "tailwindcss -i src/renderer/style.css -o dist/renderer/style.css --watch",
    "watch:ts": "tsc -w",
    "build:css": "tailwindcss -i src/renderer/style.css -o dist/renderer/style.css --minify",
    "build:ts": "tsc",
    "build": "npm run build:ts && npm run build:css",
    "start": "electron .",
    "package": "npm run build && electron-builder"
  },
  "devDependencies": {
    "@types/node": "^20.10.0",
    "concurrently": "^8.2.2",
    "electron": "^28.0.0",
    "electron-builder": "^24.9.1",
    "tailwindcss": "^3.4.0",
    "typescript": "^5.3.0",
    "wait-on": "^7.2.0"
  },
  "build": {
    "appId": "com.yourcompany.app",
    "productName": "Your App",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "package.json"
    ],
    "win": {
      "target": "nsis"
    },
    "mac": {
      "target": "dmg"
    },
    "linux": {
      "target": "AppImage"
    }
  }
}
