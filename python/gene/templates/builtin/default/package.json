{
  "name": "{{ project_name }}",
  "version": "1.0.0",
  "private": true,
  "description": "{{ project_name }} — A Gene desktop application",
  "main": "electron/main.js",
  "scripts": {
    "dev": "gene dev",
    "dev:frontend": "cd frontend && npx vite --port 3000",
    "dev:backend": "cd backend && python -m uvicorn app:app --reload --port 18764",
    "build": "gene build",
    "package": "gene package",
    "start": "electron ."
  },
  "dependencies": {
    "ws": "^8.16.0"
  },
  "devDependencies": {
    "electron": "^28.1.3",
    "electron-builder": "^24.9.1"
  },
  "build": {
    "appId": "com.gene.{{ project_name_slug }}",
    "productName": "{{ project_name }}",
    "asar": true,
    "asarUnpack": "resources/python/**",
    "extraResources": [
      {
        "from": "backend/dist/",
        "to": "python",
        "filter": ["**/*"]
      }
    ],
    "win": { "target": "nsis" },
    "mac": { "target": "dmg" },
    "linux": { "target": "AppImage" }
  }
}
